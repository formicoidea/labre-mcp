# ── Dependencies ──────────────────────────────
node_modules/

# ── Build output ──────────────────────────────
dist/
*.tsbuildinfo

# ── Turborepo ────────────────────────────────
.turbo/

# ── Environment & secrets ─────────────────────
.env
.env.local
.env.*.local

# ── Per-user LLM routing config ───────────────
# llm.config.json is per-machine: each user picks a profile from
# llm.config.example.json and adapts it locally (pick provider, models,
# effort, etc.). The canonical example stays tracked.
llm.config.json

# ── Package manager ───────────────────────────
# pnpm is the project's package manager; ignore npm/yarn lockfiles
package-lock.json
yarn.lock

# ── IDE / Editor ──────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ── OS files ──────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Claude Code ───────────────────────────────
.claude/
.omc/

# ── Logs & debug ──────────────────────────────
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# ── Test & coverage ───────────────────────────
coverage/
.nyc_output/

# ── Temporary files ───────────────────────────
tmp/
tmp/renders/
*.tmp

# Exclude large output files
evaluations/*.html
evaluations/*.json

# But keep summary reports
!evaluations/summary-*.csv