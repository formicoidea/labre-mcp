{
  "schemaVersion": "1.0",
  "name": "generate",
  "domain": "wardley",
  "tool": "map",
  "description": "Generate a complete Wardley map (anchors, components, links, layout) from a natural-language command, then emit it as OWM DSL.",
  "steps": [
    {
      "stepId": "build",
      "tool": "wardley:map:value-chain:generate:top-down",
      "in": "$.input",
      "out": "$.chain"
    },
    {
      "stepId": "place-labels",
      "tool": "wardley:map:value-chain:prevent-collision:default",
      "in": "$.chain.result",
      "out": "$.laid"
    },
    {
      "stepId": "verify",
      "tool": "wardley:map:value-chain:audit:overlap-check",
      "in": "$.laid.result",
      "out": "$.verified"
    },
    {
      "stepId": "emit",
      "tool": "render:wardley-map:owm:emit:dsl",
      "in": "$.verified.result",
      "out": "$.output"
    }
  ],
  "listeners": []
}
