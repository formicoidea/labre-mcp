{
  "schemaVersion": "1.0",
  "name": "generate",
  "domain": "wardley",
  "tool": "chain",
  "description": "Generate a complete Wardley chain map (anchors, components, links, layout) from a natural-language command, then emit it as OWM DSL.",
  "steps": [
    {
      "stepId": "build",
      "tool": "wardley:chain:write:map:top-down",
      "in": "$.input",
      "out": "$.chain"
    },
    {
      "stepId": "place-labels",
      "tool": "common:layout:write:labels:default",
      "in": "$.chain.result",
      "out": "$.laid"
    },
    {
      "stepId": "verify",
      "tool": "common:layout:quality:overlaps:default",
      "in": "$.laid.result",
      "out": "$.verified"
    },
    {
      "stepId": "emit",
      "tool": "wardley:chain:emit:owm:standard",
      "in": "$.verified.result",
      "out": "$.output"
    }
  ],
  "listeners": []
}
