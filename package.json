{
  "name": "labre-mcp",
  "version": "0.1.0",
  "description": "MCP server for applying practice frameworks — Wardley Maps first (value chain, evolution, climates, doctrines). Strategy registry + recipe runner, exposed over stdio (Claude Code / Agent SDK) or HTTP.",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "bin": {
    "labre-mcp": "./dist/core/transport/labre-stdio.mjs"
  },
  "files": [
    "dist",
    "recipes",
    "prompts",
    "prompts.config.json",
    "llm.config.example.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/formicoidea/labre-mcp.git"
  },
  "homepage": "https://github.com/formicoidea/labre-mcp#readme",
  "bugs": {
    "url": "https://github.com/formicoidea/labre-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "imports": {
    "#core/*": { "development": "./src/core/*", "default": "./dist/core/*" },
    "#frameworks/*": { "development": "./src/frameworks/*", "default": "./dist/frameworks/*" },
    "#lib/*": { "development": "./src/lib/*", "default": "./dist/lib/*" },
    "#types/*": { "development": "./src/types/*", "default": "./dist/types/*" },
    "#schemas/*": { "development": "./src/schemas/*", "default": "./dist/schemas/*" },
    "#mcp/*": { "development": "./src/mcp/*", "default": "./dist/mcp/*" },
    "#session/*": { "development": "./src/session/*", "default": "./dist/session/*" },
    "#work-on-evolution/*": {
      "development": "./src/frameworks/wardley/evolution/_legacy/*",
      "default": "./dist/frameworks/wardley/evolution/_legacy/*"
    },
    "#work-on-value-chain/*": {
      "development": "./src/frameworks/wardley/chain/_legacy/*",
      "default": "./dist/frameworks/wardley/chain/_legacy/*"
    }
  },
  "scripts": {
    "mcp": "tsx --conditions development src/core/transport/labre-daemon.mts",
    "mcp:prod": "node dist/core/transport/labre-daemon.mjs",
    "mcp:stdio": "tsx --conditions development src/core/transport/labre-stdio.mts",
    "mcp:stdio:prod": "node dist/core/transport/labre-stdio.mjs",
    "build": "tsc",
    "dev": "tsx --conditions development src/core/transport/labre-daemon.mts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --conditions development --test \"src/**/*.test.mts\"",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "wardley-maps",
    "wardley",
    "strategy",
    "claude",
    "claude-code"
  ],
  "author": "Mathieu Jolly <mathieujolly01@gmail.com>",
  "license": "ISC",
  "packageManager": "pnpm@10.21.0",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.87",
    "@formicoidea/wardley-map-renderer": "^1.0.0-beta.0",
    "@github/copilot-sdk": "0.2.2",
    "@google-cloud/bigquery": "^8.1.1",
    "@hono/node-server": "^2.0.2",
    "hono": "^4.12.18",
    "jsonpath-plus": "^10.4.0",
    "lodash.merge": "^4.6.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
