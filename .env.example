# Required for any strategy mapped to an http-api provider.
# The default llm.config.json routes `logprob-distribution` to OpenCode, which needs this key.
OPENCODE_API_KEY=

# Optional: GitHub Copilot SDK auth.
# Only read when a strategy in llm.config.json routes to a provider of kind `copilot-sdk`.
# When unset, the Copilot SDK falls back to `gh auth login` credentials, GH_TOKEN, or GITHUB_TOKEN.
# COPILOT_GITHUB_TOKEN=

# Optional: absolute or project-relative path to an alternate LLM config file.
# When set, overrides the default `<repo>/llm.config.json`.
# The default `llm.config.json` is gitignored (per-user) — start from
# `llm.config.example.json` and adapt (`cp llm.config.example.json llm.config.json`).
# WARDLEY_LLM_CONFIG=./llm.config.local.json

# Optional: absolute or project-relative path to an alternate prompts config file.
# When set, overrides the default `<repo>/prompts.config.json`.
# WARDLEY_PROMPTS_CONFIG=./prompts.config.local.json

# Optional runtime flags
# WARDLEY_VERBOSE=1
# WARDLEY_EVAL_MODE=exclusive

# Optional: absolute path to labre-mcp's own install root.
# Auto-detected from the running file location in dev (tsx) and standard
# prod layouts (dist/...). Set this explicitly when running from a bundled
# build that flattens the source layout, otherwise shipped recipes will
# not resolve.
# LABRE_SHIPPED_ROOT=/opt/labre-mcp

# Optional: HTTP port the daemon listens on. Default: 3000.
# LABRE_HTTP_PORT=3000

# Patent CPC source (only needed when using the cpc-evolution strategy)
# BIGQUERY_PROJECT_ID=
