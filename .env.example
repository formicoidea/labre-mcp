# Required for any strategy mapped to an http-api provider.
# The default llm.config.json routes `logprob-distribution` to OpenCode, which needs this key.
OPENCODE_API_KEY=

# Optional: GitHub Copilot SDK auth.
# Only read when a strategy in llm.config.json routes to a provider of kind `copilot-sdk`.
# When unset, the Copilot SDK falls back to `gh auth login` credentials, GH_TOKEN, or GITHUB_TOKEN.
# COPILOT_GITHUB_TOKEN=

# Optional: absolute or project-relative path to an alternate LLM config file.
# When set, overrides the default `<repo>/llm.config.json`.
# The default `llm.config.json` is gitignored (per-user) — start from
# `llm.config.example.json` and adapt (`cp llm.config.example.json llm.config.json`).
# WARDLEY_LLM_CONFIG=./llm.config.local.json

# Optional: absolute or project-relative path to an alternate prompts config file.
# When set, overrides the default `<repo>/prompts.config.json`.
# WARDLEY_PROMPTS_CONFIG=./prompts.config.local.json

# Optional runtime flags
# WARDLEY_VERBOSE=1
# WARDLEY_EVAL_MODE=exclusive

# Optional: absolute path to labre-mcp's own install root.
# Auto-detected from the running file location in dev (tsx) and standard
# prod layouts (dist/...). Set this explicitly when running from a bundled
# build that flattens the source layout, otherwise shipped recipes will
# not resolve.
# LABRE_SHIPPED_ROOT=/opt/labre-mcp

# Optional: HTTP port the daemon listens on. Default: 6767.
# LABRE_HTTP_PORT=6767

# Optional: bind address for the HTTP daemon. Default: 127.0.0.1 (loopback,
# local dev). Set to 0.0.0.0 when running behind a PaaS router so the
# platform's external router can reach the process.
# LABRE_HTTP_HOST=0.0.0.0

# Optional: shared ops secret gating GET /config/llm (read-only LLM config for
# the Labre admin console). Same string on both sides — the daemon (this env)
# and its sole consumer, the admin console. Distinct from per-user auth. The
# feature is opt-in: unset = endpoint disabled (503), daemon otherwise unaffected.
# Callers send: Authorization: Bearer <token>.
# LABRE_MCP_ADMIN_TOKEN=

# Patent CPC source (only needed when using the cpc-evolution strategy)
# BIGQUERY_PROJECT_ID=

# ─── HTTP daemon auth + remote strategy bundles ──────────────────────────────
# LABRE_AUTH is a comma-separated list of the auth doors to open:
#   supabase  Supabase session JWTs (JWKS from SUPABASE_URL); reaches agent.reply RLS
#   oidc      any OIDC IdP JWTs (AUTH_JWKS_URL + AUTH_AUDIENCE)
#   api-key   lab_ personal keys (SUPABASE_URL + SUPABASE_ANON_KEY)
# Unset / "none" / empty keeps the local noop auth. Each listed door fails closed
# on its own env. Examples: supabase,oidc,api-key | oidc | api-key
# LABRE_AUTH=supabase,api-key
# SUPABASE_URL=https://xyzcompany.supabase.co
# Optional: expected `aud` claim (default "authenticated").
# SUPABASE_JWT_AUD=authenticated

# Public anon key — enables the remote strategy-bundle source (bundles are
# fetched with the CALLER's JWT + this key; RLS authorizes; the daemon never
# holds a service-role key) AND lab_ personal API keys (validated through the
# labre_mcp.validate_api_key RPC). Without it, both features are off.
# SUPABASE_ANON_KEY=

# Optional: freshness window (seconds) for the remote bundle refresh. Default: 300.
# LABRE_BUNDLES_TTL_S=300

# ─── OAuth protected-resource discovery (opt-in, RFC 9728) ───────────────────
# Lets OAuth-capable MCP clients (claude.ai connectors) discover that the labre
# app is the authorization server for this daemon. The daemon stays a pure
# RESOURCE server (it validates tokens, never mints them — set LABRE_AUTH=oidc
# with the labre app's JWKS to accept its tokens). Set BOTH or neither; unset =
# no discovery surface, static bearers (JWT / lab_) unaffected.
#   LABRE_OAUTH_RESOURCE       the public MCP URL (this daemon, behind its CNAME)
#   LABRE_OAUTH_AUTH_SERVER    the labre app base URL (the authorization server)
# LABRE_OAUTH_RESOURCE=https://framework-mcp.labre.app/mcp
# LABRE_OAUTH_AUTH_SERVER=https://labre.app
